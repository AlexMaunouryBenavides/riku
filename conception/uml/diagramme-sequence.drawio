        <!-- ===================== FRAME LOOP (UC11) ===================== -->
        <mxCell id="frame" value="loop  [pour chaque question servie]" style="shape=umlFrame;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;fontStyle=2;align=left;verticalAlign=top;width=150;height=24;" vertex="1" parent="1">
          <mxGeometry x="60" y="372" width="1290" height="376" as="geometry"/>
        </mxCell>

        <!-- ===================== MESSAGES : UC10 (démarrer) ===================== -->
        <!-- centres X : UI=110 CTRL=340 SVC=570 POL=800 SQL=1030 MDB=1260 -->

        <mxCell id="m1" value="1: POST /revision/sessions {themeIds}" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
