        </mxCell>
        <mxCell id="m2" value="2: startSession(userId, themeIds)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="340" y="142" as="sourcePoint"/><mxPoint x="570" y="142" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="3: selectDueCards(userId, themeIds, N)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
