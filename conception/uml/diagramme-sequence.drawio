        <!-- self message : correction côté serveur -->
        <mxCell id="m13" value="8: isCorrect = equals(chosen, correctIds)  // correction CÔTÉ SERVEUR" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
