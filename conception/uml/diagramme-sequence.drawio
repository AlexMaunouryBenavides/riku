        <mxCell id="m8" value="201 Created {sessionId, question}" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="340" y="334" as="sourcePoint"/><mxPoint x="110" y="334" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ===================== MESSAGES : UC11 (répondre) ===================== -->

        <mxCell id="m9" value="5: POST /revision/sessions/{id}/answers {questionId, chosen[]}" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
