# Modèle de configuration — versionné, sans aucune valeur sensible (configuration.r4).
# Copier en `.env` (git-ignoré) et renseigner les valeurs locales.
#
# Test décisif 12-Factor : ce dépôt pourrait-il devenir public à l'instant
# sans compromettre un credential ? Si tu ajoutes une clé ici, laisse-la vide.

# ─── MySQL (données relationnelles : utilisateurs, thèmes, questions, cartes) ───
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=riku
MYSQL_USER=riku
MYSQL_PASSWORD=
# Port exposé sur l'hôte. Si une installation MySQL native tourne déjà sur ce
# poste, désactive son service plutôt que de décaler ce port : deux serveurs
# concurrents mènent tôt ou tard à migrer la mauvaise base.
MYSQL_PORT=3306

# ─── MongoDB (journal des sessions de révision et des réponses données) ───
MONGO_ROOT_USERNAME=riku
MONGO_ROOT_PASSWORD=
MONGO_DATABASE=riku
MONGO_PORT=27017
