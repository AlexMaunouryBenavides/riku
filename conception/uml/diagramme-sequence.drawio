        </mxCell>
        <mxCell id="ll_mdb" value="MongoDB (Session)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1170" y="40" width="180" height="720" as="geometry"/>
