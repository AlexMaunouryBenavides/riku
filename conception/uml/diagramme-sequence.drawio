        <mxCell id="m7" value="session + 1ère question (SANS les réponses correctes)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="570" y="302" as="sourcePoint"/><mxPoint x="340" y="302" as="targetPoint"/></mxGeometry>
